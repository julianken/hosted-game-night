# =============================================================================
# Beak Gaming Platform - Root Environment Variables
# =============================================================================
# These are shared configuration values used across all apps.
# Each app also has its own .env.example with app-specific variables.

# -----------------------------------------------------------------------------
# Turbo Remote Caching (Optional)
# Speeds up builds by caching artifacts remotely
# Get token from: https://vercel.com/account/tokens
# -----------------------------------------------------------------------------
TURBO_TOKEN=your-turbo-token
TURBO_TEAM=your-team-name
TURBO_REMOTE_ONLY=true

# -----------------------------------------------------------------------------
# Supabase Configuration
# All apps share the same Supabase project
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# E2E Testing Configuration (Optional)
# -----------------------------------------------------------------------------
# Enable E2E test mode to bypass rate limiting during Playwright test runs
# This allows 6 parallel workers to run without hitting the 10 req/min limit
# Rate limiting remains active in dev/production environments
# Set to "true" when running E2E tests: pnpm test:e2e
E2E_TESTING=true
